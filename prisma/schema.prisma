datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Citizen {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  birthDate     String
  gender        String
  phoneNumber   String?
  driverLicense String    @default("AKTIV") // AKTIV, GESPERRT, KEINE
  weaponLicense String    @default("KEINER") // AKTIV, ENTZOGEN, KEINER
  notes         String?
  warrants      Warrant[]
  suspects      Suspect[]
  createdAt     DateTime  @default(now())
}

model Case {
  id             String      @id @default(uuid())
  caseNumber     String      @unique // E.g. "12 Js 432/26"
  title          String
  description    String
  status         String      @default("ERMITTLUNG") // ERMITTLUNG, ANKLAGE, ARCHIV
  urgency        String      @default("MITTEL") // NIEDRIG, MITTEL, HOCH, KRITISCH
  creatorName    String
  creatorRole    String
  suspects       Suspect[]
  evidences      Evidence[]
  documents      Document[]  // Beschlüsse, Urteile, Protokolle
  notes          CaseNote[]  // Chronologischer Verlauf
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Suspect {
  id            String   @id @default(uuid())
  caseId        String
  citizenId     String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  citizen       Citizen  @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  charges       String   // JSON String der Gesetze
  fine          Int      @default(0)
  jailTime      Int      @default(0)
  pleadedGuilty Boolean  @default(false)
}

model Evidence {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title       String
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model Document {
  id          String    @id @default(uuid())
  caseId      String
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type        String    // BESCHLUSS, URTEIL, PROTOKOLL
  title       String
  content     String
  signedBy    String?   // Name des Richters, der unterschrieben hat
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model CaseNote {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  content     String
  authorName  String
  createdAt   DateTime @default(now())
}

model Warrant {
  id          String   @id @default(uuid())
  citizenId   String
  citizen     Citizen  @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  reason      String
  creatorName String
  status      String   @default("AKTIV") // AKTIV, ERLEDIGT
  createdAt   DateTime @default(now())
}

model InternalDocument {
  id          String    @id @default(uuid())
  type        String    // DIENSTANWEISUNG, DIENSTORDNUNG, ANTRAG, BESCHWERDE
  title       String
  content     String
  creatorName String
  creatorRole String
  signedBy    String?   // Amtliche Zeichnung/Genehmigung
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
